# ─── Local Development Environment ──────────
# Copy this to .env.local and adjust values

# ─── Database ───────────────────────────────
POSTGRES_DB=jw_reminders
POSTGRES_USER=jw_admin
POSTGRES_PASSWORD=jw_local_pass
DATABASE_URL=postgresql://jw_admin:jw_local_pass@localhost:5433/jw_reminders

# ─── Auth ────────────────────────────────────
JWT_SECRET=local_jwt_secret_change_me

# ─── App ─────────────────────────────────────
NODE_ENV=development
TIMEZONE=America/Mexico_City
REMINDER_SEND_HOUR=9

# ─── WhatsApp ────────────────────────────────
WHATSAPP_API_URL=http://localhost:3010
WHATSAPP_SESSION_PATH=./.wwebjs_auth

# ─── Test Mode ───────────────────────────────
TEST_MODE=true
TEST_PHONE=5219611234567

# ─── Worker ──────────────────────────────────
CRON_SCHEDULE=*/10 * * * *

# ─── Frontend ────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
