# ─── Database ───────────────────────────────
POSTGRES_DB=jw_reminders
POSTGRES_USER=jw_admin
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DATABASE_URL=postgresql://jw_admin:CHANGE_ME@db:5432/jw_reminders

# ─── Auth ────────────────────────────────────
JWT_SECRET=CHANGE_ME_RANDOM_SECRET

# ─── App ─────────────────────────────────────
NODE_ENV=production
TIMEZONE=America/Mexico_City
REMINDER_SEND_HOUR=9
APP_URL=https://jw-reminders.duckdns.org

# ─── WhatsApp ────────────────────────────────
WHATSAPP_API_URL=http://whatsapp:3010
WHATSAPP_SESSION_PATH=/app/.wwebjs_auth

# ─── Test Mode ───────────────────────────────
TEST_MODE=true
TEST_PHONE=521XXXXXXXXXX

# ─── Worker ──────────────────────────────────
CRON_SCHEDULE=*/10 * * * *

# ─── Frontend ────────────────────────────────
NEXT_PUBLIC_API_URL=https://jw-reminders.duckdns.org
