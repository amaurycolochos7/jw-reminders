generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────

enum Gender {
  MALE
  FEMALE
}

enum AssignmentSection {
  BIBLE_READING
  APPLY_YOURSELF
}

enum AssignmentType {
  BIBLE_READING
  START_CONVERSATION
  MAKE_RETURN_VISIT
  BIBLE_STUDY
  EXPLAIN_BELIEFS
  MAKE_DISCIPLES
  TALK
  OTHER
}

enum Room {
  MAIN
  AUXILIARY
}

enum AssignmentStatus {
  PROPOSED
  DRAFT
  SCHEDULED
  COMPLETED
  CANCELLED
}

enum ReminderType {
  INITIAL_NOTICE
  SEVEN_DAYS_BEFORE
  THREE_DAYS_BEFORE
  ONE_DAY_BEFORE
  SAME_DAY
  CHANGE_NOTICE
  CANCELLATION_NOTICE
}

enum ReminderStatus {
  PENDING
  QUEUED
  SENDING
  SENT
  FAILED
  SKIPPED
  CANCELLED
  DEAD
}

enum MessageLogStatus {
  SENT
  FAILED
  SKIPPED
}

enum WhatsappSessionStatus {
  STARTING
  QR_REQUIRED
  AUTHENTICATED
  READY
  DISCONNECTED
  FAILED
}

enum MonthlyScheduleStatus {
  DRAFT
  ACTIVE
  COMPLETED
  ARCHIVED
  CANCELLED
}

enum MeetingWeekStatus {
  DRAFT
  READY
  ACTIVE
  COMPLETED
  ARCHIVED
  CANCELLED
}

// Estado de la importación del programa real de WOL para una semana.
enum WeekImportStatus {
  EMPTY // Semana creada, aún sin programa importado.
  IMPORTING // Importación en curso.
  READY // Programa importado correctamente; se puede generar participantes.
  NEEDS_REVIEW // Se importó algo pero faltan datos o el parser no está seguro.
  IMPORT_FAILED // No se pudo importar desde WOL.
}

// Tipo de notificación para deduplicar el primer aviso por asignación/persona.
enum NotificationType {
  FIRST_ASSIGNMENT
  REMINDER
}

enum AutomationPlanStatus {
  DRAFT
  ACTIVE
  SUPERSEDED
  CANCELLED
  ARCHIVED
}

enum ReminderRecipientRole {
  ASSIGNED
  COMPANION
}

// ─── Models ──────────────────────────────────────────────

model AdminUser {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model JwPublisher {
  id                    String    @id @default(cuid())
  fullName              String
  displayName           String?
  phone                 String    @unique
  whatsappPhone         String?
  gender                Gender?
  isActive              Boolean   @default(true)
  canReceiveAssignments Boolean   @default(true)
  canBeCompanion        Boolean   @default(true)
  notes                 String?
  deletedAt             DateTime?
  // Future fields
  congregationId        String?
  email                 String?
  birthDate             DateTime?
  emergencyContact      String?
  roleNotes             String?
  tags                  String?
  metadata              Json?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  assignedAssignments  JwAssignment[]         @relation("AssignedPublisher")
  companionAssignments JwAssignment[]         @relation("CompanionPublisher")
  reminders            JwAssignmentReminder[]
  reminderDeliveries   ReminderDelivery[]
  messageLogs          JwMessageLog[]
  notificationLogs     NotificationLog[]
}

model MonthlySchedule {
  id          String                @id @default(cuid())
  year        Int
  month       Int
  name        String
  status      MonthlyScheduleStatus @default(DRAFT)
  archivedAt  DateTime?
  cancelledAt DateTime?
  completedAt DateTime?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  weeks JwMeetingWeek[]

  @@unique([year, month])
}

model JwMeetingWeek {
  id                 String            @id @default(cuid())
  monthlyScheduleId  String?
  weekStartDate      DateTime
  weekStartDateLocal String?
  meetingDate        DateTime
  meetingDateLocal   String?
  meetingTime        String
  congregationName   String?
  notes              String?
  status             MeetingWeekStatus @default(DRAFT)
  archivedAt         DateTime?
  cancelledAt        DateTime?
  completedAt        DateTime?
  // ─── Integración con WOL (Vida y Ministerio) ───
  isoYear            Int? // Año ISO que corresponde a la semana (para la URL de WOL).
  isoWeekNumber      Int? // Número de semana ISO (1..53).
  wolMeetingsUrl     String? // https://wol.jw.org/es/wol/meetings/r4/lp-s/{year}/{week}
  wolProgramUrl      String? // Enlace real del programa de esa semana (/wol/d/...).
  importStatus       WeekImportStatus  @default(EMPTY)
  importedAt         DateTime?
  importError        String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  monthlySchedule MonthlySchedule? @relation(fields: [monthlyScheduleId], references: [id])
  assignments     JwAssignment[]
  assignmentTemplates AssignmentTemplate[]
  programItems    MeetingProgramItem[]

  @@index([monthlyScheduleId])
  @@index([status])
  @@index([importStatus])
}

model JwAssignment {
  id                     String            @id @default(cuid())
  meetingWeekId          String
  assignmentNumber       Int
  section                AssignmentSection
  assignmentType         AssignmentType
  title                  String
  durationMinutes        Int?
  context                String?
  reference              String?
  assignedPublisherId    String
  companionPublisherId   String?
  assignedNameSnapshot   String?
  assignedPhoneSnapshot  String?
  companionNameSnapshot  String?
  companionPhoneSnapshot String?
  room                   Room
  notes                  String?
  status                 AssignmentStatus  @default(DRAFT)
  version                Int               @default(1)
  programItemId          String? // Item real de WOL sobre el que se asigna (si aplica).
  completedAt            DateTime?
  cancelledAt            DateTime?
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt

  meetingWeek        JwMeetingWeek          @relation(fields: [meetingWeekId], references: [id])
  assigned           JwPublisher            @relation("AssignedPublisher", fields: [assignedPublisherId], references: [id])
  companion          JwPublisher?           @relation("CompanionPublisher", fields: [companionPublisherId], references: [id])
  programItem        MeetingProgramItem?    @relation(fields: [programItemId], references: [id])
  reminders          JwAssignmentReminder[]
  automationPlans    AutomationPlan[]
  reminderDeliveries ReminderDelivery[]
  messageLogs        JwMessageLog[]
  notificationLogs   NotificationLog[]

  @@index([meetingWeekId, status])
  @@index([assignedPublisherId])
  @@index([companionPublisherId])
  @@index([programItemId])
}

model AssignmentTemplate {
  id               String            @id @default(cuid())
  meetingWeekId    String
  order            Int
  assignmentNumber Int
  section          AssignmentSection
  assignmentType   AssignmentType
  title            String
  durationMinutes  Int?
  needsCompanion   Boolean           @default(false)
  room             Room              @default(MAIN)
  reference        String?
  source           String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  meetingWeek JwMeetingWeek @relation(fields: [meetingWeekId], references: [id])

  @@unique([meetingWeekId, assignmentNumber])
  @@index([meetingWeekId])
}

model AutomationPlan {
  id               String               @id @default(cuid())
  assignmentId     String
  status           AutomationPlanStatus @default(DRAFT)
  version          Int                  @default(1)
  timezone         String
  sendHour         Int
  meetingDateLocal String
  meetingTimeLocal String
  rules            Json
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  cancelledAt      DateTime?
  supersededAt     DateTime?
  archivedAt       DateTime?

  assignment         JwAssignment       @relation(fields: [assignmentId], references: [id])
  reminderDeliveries ReminderDelivery[]
  messageLogs        JwMessageLog[]

  @@unique([assignmentId, version])
  @@index([assignmentId, status])
}

model ReminderDelivery {
  id               String                @id @default(cuid())
  automationPlanId String
  assignmentId     String
  publisherId      String
  recipientRole    ReminderRecipientRole
  reminderType     ReminderType
  scheduledAt      DateTime
  sentAt           DateTime?
  status           ReminderStatus        @default(PENDING)
  customMessage    String?
  attemptCount     Int                   @default(0)
  maxAttempts      Int                   @default(3)
  nextRetryAt      DateTime?
  lastAttemptAt    DateTime?
  deadAt           DateTime?
  errorMessage     String?
  cancelledAt      DateTime?
  cancelReason     String?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  automationPlan AutomationPlan @relation(fields: [automationPlanId], references: [id])
  assignment     JwAssignment   @relation(fields: [assignmentId], references: [id])
  publisher      JwPublisher    @relation(fields: [publisherId], references: [id])
  messageLogs    JwMessageLog[]

  @@unique([automationPlanId, publisherId, reminderType])
  @@index([status, scheduledAt])
  @@index([assignmentId, status])
  @@index([publisherId, status])
  @@index([automationPlanId, status])
}

model JwAssignmentReminder {
  id               String                 @id @default(cuid())
  automationPlanId String?
  recipientRole    ReminderRecipientRole?
  assignmentId     String
  publisherId      String
  reminderDay      ReminderType
  scheduledAt      DateTime
  sentAt           DateTime?
  status           ReminderStatus         @default(PENDING)
  errorMessage     String?
  cancelledAt      DateTime?
  cancelReason     String?
  generationKey    String?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  assignment JwAssignment @relation(fields: [assignmentId], references: [id])
  publisher  JwPublisher  @relation(fields: [publisherId], references: [id])

  @@unique([assignmentId, publisherId, reminderDay])
  @@index([automationPlanId, status])
  @@index([status, scheduledAt])
}

model JwMessageTemplate {
  id        String   @id @default(cuid())
  type      String   @unique
  title     String
  body      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model JwMessageLog {
  id                 String           @id @default(cuid())
  assignmentId       String?
  publisherId        String?
  automationPlanId   String?
  reminderDeliveryId String?
  phone              String
  messageType        String?
  messageBody        String
  providerMessageId  String?
  status             MessageLogStatus
  errorMessage       String?
  sentAt             DateTime?
  createdAt          DateTime         @default(now())

  assignment       JwAssignment?     @relation(fields: [assignmentId], references: [id])
  publisher        JwPublisher?      @relation(fields: [publisherId], references: [id])
  automationPlan   AutomationPlan?   @relation(fields: [automationPlanId], references: [id])
  reminderDelivery ReminderDelivery? @relation(fields: [reminderDeliveryId], references: [id])

  @@index([automationPlanId])
  @@index([reminderDeliveryId])
}

model JwAutomationEvent {
  id         String   @id @default(cuid())
  eventType  String
  entityType String
  entityId   String
  actorType  String?
  actorId    String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([eventType])
  @@index([entityType, entityId])
  @@index([createdAt])
}

model JwWhatsappSessionLog {
  id        String                @id @default(cuid())
  status    WhatsappSessionStatus
  message   String?
  createdAt DateTime              @default(now())
}

model AppConfig {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

// Programa real de una semana importado desde WOL (Vida y Ministerio).
// Es la fuente sobre la que se asignan personas; nunca se inventa.
model MeetingProgramItem {
  id              String   @id @default(cuid())
  meetingWeekId   String
  itemNumber      Int? // Número de la parte en WOL (4, 5, 6...). Null en Lectura de la Biblia.
  section         String? // Sección general, p. ej. "Seamos mejores maestros".
  title           String // "Lectura de la Biblia", "Empiece conversaciones"...
  assignmentType  AssignmentType @default(OTHER)
  durationMinutes Int?
  context         String? // "PREDICACIÓN INFORMAL", "DE CASA EN CASA".
  description     String? // Instrucción completa.
  reference       String? // "lmd lección 1 punto 4".
  lesson          String? // "th lección 2".
  requiresAssistant Boolean @default(false)
  sourceUrl       String? // URL de WOL de origen.
  sortOrder       Int      @default(0)
  rawText         String? // Texto original extraído (auditoría).
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  meetingWeek JwMeetingWeek  @relation(fields: [meetingWeekId], references: [id])
  assignments JwAssignment[]

  // Upsert estable por semana + posición (sortOrder). itemNumber puede ser null
  // (p. ej. Lectura de la Biblia) y los títulos podrían repetirse, por lo que la
  // posición dentro de la semana es el identificador confiable.
  @@unique([meetingWeekId, sortOrder])
  @@index([meetingWeekId])
}

// Registro de notificaciones para evitar duplicados (primer aviso) y auditar envíos.
model NotificationLog {
  id                String           @id @default(cuid())
  assignmentId      String
  recipientPersonId String
  notificationType  NotificationType
  // Clave fina de deduplicación. FIRST_ASSIGNMENT se envía una sola vez, pero los
  // recordatorios se distinguen por clave (REMINDER_7_DAYS, REMINDER_3_DAYS,
  // REMINDER_1_DAY, REMINDER_SAME_DAY...) para permitir varios sin duplicar.
  notificationKey   String
  status            MessageLogStatus
  sentAt            DateTime?
  whatsappMessageId String?
  errorMessage      String?
  createdAt         DateTime         @default(now())

  assignment JwAssignment @relation(fields: [assignmentId], references: [id])
  recipient  JwPublisher  @relation(fields: [recipientPersonId], references: [id])

  // No reenviar la misma notificación (misma clave) a la misma persona para la
  // misma asignación. Permite múltiples recordatorios con claves distintas.
  @@unique([assignmentId, recipientPersonId, notificationKey])
  @@index([assignmentId])
  @@index([recipientPersonId])
}
